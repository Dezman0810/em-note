# PostgreSQL (Docker Compose: хост сервиса — db, см. docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/note

# Запуск API на хосте (без Docker), если Postgres на localhost:5432:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/note

JWT_SECRET_KEY=replace-with-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUG=false

# Админка и выдача права на создание заметок (по умолчанию в коде: ramis.idrisov@gmail.com)
# ADMIN_EMAIL=ramis.idrisov@gmail.com

# Optional S3
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
