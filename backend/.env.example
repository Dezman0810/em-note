# Скопируйте в `.env` и подставьте значения.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/note
JWT_SECRET_KEY=смените-на-длинную-случайную-строку

# Локальные вложения (Docker Compose монтирует том в /app/data/attachments)
# ATTACHMENTS_DIR=/app/data/attachments
# MAX_ATTACHMENT_BYTES=26214400
