# Скопируйте в `.env` и подставьте значения.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/note
JWT_SECRET_KEY=смените-на-длинную-случайную-строку

# Локальные вложения (Docker Compose монтирует том в /app/data/attachments)
# ATTACHMENTS_DIR=/app/data/attachments
# MAX_ATTACHMENT_BYTES=26214400

# Распознавание аудио (Vosk): в Docker-образе API модель уже в /opt/vosk-model/... (см. Dockerfile).
# Только локальный запуск без Docker — скачайте модель и укажите путь:
# VOSK_MODEL_PATH=/absolute/path/to/vosk-model-small-ru-0.22
# Docker (docker-compose): FFMPEG_PATH задаётся в compose, обычно не нужен в .env
# Локально на Windows без Docker — полный путь или оставьте пустым (тогда imageio-ffmpeg)
# FFMPEG_PATH=C:\Program Files\Gyan\FFmpeg\bin\ffmpeg.exe
