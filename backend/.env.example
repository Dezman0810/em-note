# SQLite (файл рядом с приложением) — локально и dev Docker (том ./backend)
DATABASE_URL=sqlite+aiosqlite:///./note.db

# Docker prod (docker-compose.prod.yml): данные в томе /app/data
# DATABASE_URL=sqlite+aiosqlite:///./data/note.db

# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/note

JWT_SECRET_KEY=replace-with-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUG=false

# Optional S3
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
